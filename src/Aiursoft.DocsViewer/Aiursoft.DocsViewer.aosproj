<Project Sdk="Aiursoft.Apkg.Sdk">
  <PropertyGroup>
    <PackageName>aiursoft-docsViewer</PackageName>
    <PackageVersion>1.0.1</PackageVersion>
    <PackageAuthors>Anduin Xue &lt;anduin@aiursoft.com&gt;</PackageAuthors>
    <PackageDescription>Aiursoft DocsViewer Web Application</PackageDescription>
    <TargetDistro>anduinos</TargetDistro>
    <TargetSuites>noble-webapps questing-webapps resolute-webapps</TargetSuites>
    <TargetArchitectures>amd64 arm64</TargetArchitectures>
    <Component>main</Component>
    <DependencyCheckUrl>https://mirror.aiursoft.com/ubuntu</DependencyCheckUrl>
    <DependencyCheckSuiteMap>noble-webapps=noble-updates questing-webapps=questing resolute-webapps=resolute</DependencyCheckSuiteMap>
  </PropertyGroup>

  <ItemGroup>
    <PrebuildCommand Run="rm -rf bin/publish" />
    <PrebuildCommand Run="npm ci --prefix wwwroot" />
    <PrebuildCommand Run="dotnet publish Aiursoft.DocsViewer.csproj --configuration Release --no-self-contained --runtime linux-x64 --output bin/publish/" Condition="'$(Arch)' == 'amd64'" />
    <PrebuildCommand Run="dotnet publish Aiursoft.DocsViewer.csproj --configuration Release --no-self-contained --runtime linux-arm64 --output bin/publish/" Condition="'$(Arch)' == 'arm64'" />
    <PrebuildCommand Run="cp -r wwwroot/* bin/publish/wwwroot/" />
    <PrebuildCommand Run="sed -i 's|DataSource=app.db|DataSource=/var/lib/aiursoft-docsViewer/app.db|g' bin/publish/appsettings.json" />
    <PrebuildCommand Run="sed -i 's|/tmp/data|/var/lib/aiursoft-docsViewer/storage|g' bin/publish/appsettings.json" />
  </ItemGroup>

  <ItemGroup>
    <Dependency Include="dotnet-runtime-10.0" />
    <Dependency Include="aspnetcore-runtime-10.0" />
  </ItemGroup>

  <ItemGroup>
    <IncludeFolder Include="bin/publish/" Target="/usr/share/aiursoft-docsViewer" />
    <ConfFile Include="bin/publish/appsettings.json" Target="/etc/aiursoft-docsViewer/appsettings.json" />
  </ItemGroup>

  <ItemGroup>
    <PostInstallScript Include="postinst.sh" />
  </ItemGroup>

  <ItemGroup>
    <SystemdUnit Include="aiursoft-docsViewer.service" AutoEnable="true" />
  </ItemGroup>
</Project>
