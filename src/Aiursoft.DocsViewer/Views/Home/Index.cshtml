@model Aiursoft.DocsViewer.Models.HomeViewModels.IndexViewModel
@{
    ViewData["Title"] = "Home";


    <link rel="stylesheet" href="~/styles/markdown-reader.css" asp-append-version="true" />
}

<div class="container-fluid mt-3">
    <div class="row">
        <!-- Sidebar Tree Column -->
        
        
        <!-- Main Content Column -->
        <div class="col-md-12">
            @if (Model.HasReadme)
            {
                <div class="card shadow-sm mb-4">
                    <div class="card-body markdown-content">
                        @Html.Raw(Model.ReadmeHtml)
                    </div>
                    @if (Model.DocumentId.HasValue)
                    {
                        <div class="card-footer bg-white text-end">
                            <a href="/Documents/DetailById/@Model.DocumentId.Value" class="btn btn-outline-primary btn-sm">
                                <i class="lucide lucide-book-open"></i> Read full document
                            </a>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="alert alert-info shadow-sm">
                    <i class="lucide lucide-info me-2"></i> @Html.Raw(Model.ReadmeHtml)
                </div>
                
                <div class="text-center mt-5">
                    <img src="~/logo.svg" alt="Logo" style="width: 150px; opacity: 0.2;" />
                    <h3 class="mt-3 text-muted">Welcome to DocsViewer</h3>
                    <p class="text-muted">Sync your Git repository containing markdown files to get started.</p>
                </div>
            }
        </div>
    </div>
</div>

    <partial name="_CodeAssets" />

