@using Aiursoft.DocsViewer.Authorization
@using Aiursoft.DocsViewer.Services.FileStorage
@using Microsoft.AspNetCore.Authorization
@using Aiursoft.WebTools
@using Microsoft.Extensions.Localization
@model Aiursoft.DocsViewer.Models.UsersViewModels.DetailsViewModel
@inject IStringLocalizer<AppPermissions> PermissionLocalizer
@inject StorageService StorageService
@inject IAuthorizationService AuthorizationService

<div class="row mb-2 mb-xl-3" xmlns="http://www.w3.org/1999/html">
    <div class="col-auto d-none d-sm-block">
        <h3>@Localizer["User Details:"] <span class="text-muted">@Model.User.UserName</span></h3>
    </div>
    <div class="col-auto ms-auto text-end mt-n1">
        <a asp-action="Edit" asp-route-id="@Model.User.Id" class="btn btn-primary">@Localizer["Edit this User"]</a>
        <a asp-action="Delete" asp-route-id="@Model.User.Id" class="btn btn-danger">@Localizer["Delete this User"]</a>
        <a asp-action="Index" class="btn btn-light">@Localizer["Back to list"]</a>
    </div>
</div>

<div class="row">
    <div class="col-md-4 col-xl-3">
        <div class="card mb-3">
            <div class="card-header">
                <h5 class="card-title mb-0">@Localizer["Profile Details"]</h5>
            </div>
            <div class="card-body text-center">
                <a href="@StorageService.RelativePathToInternetUrl(Model.User.AvatarRelativePath)" target="_blank" rel="noopener noreferrer">
                    <img src="@StorageService.RelativePathToInternetUrl(Model.User.AvatarRelativePath)?w=256&square=true" alt="@Model.User.DisplayName" class="img-fluid rounded-circle mb-2" width="128" height="128"/>
                </a>
                <h5 class="card-title mb-0">@Model.User.DisplayName</h5>
                <div class="text-muted mb-2">@Model.User.Email</div>
            </div>
        </div>
    </div>

    <div class="col-md-8 col-xl-9">
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="card-title mb-0"><i class="align-middle me-2" data-lucide="user"></i> @Localizer["Account Details"]</h5>
            </div>
            <div class="list-group list-group-flush">
                <div class="list-group-item">
                    <div class="row">
                        <strong class="col-sm-3">@Localizer["User name"]</strong>
                        <div class="col-sm-9">@Model.User.UserName</div>
                    </div>
                </div>
                <div class="list-group-item">
                    <div class="row">
                        <strong class="col-sm-3">@Localizer["Creation Time"]</strong>
                        <div class="col-sm-9">
                            <label data-utc-time="@Model.User.CreationTime.ToHtmlDateTime()" class="text-monospace"></label>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="card flex-fill mb-4">
            <div class="card-header">
                <h5 class="card-title mb-0"><i class="align-middle me-2" data-lucide="award"></i> @Localizer["Assigned Roles"]</h5>
            </div>
            <div class="card-body">
                @if (Model.Roles.Any())
                {
                    @foreach (var role in Model.Roles)
                    {
                        <a asp-controller="Roles" asp-action="Details" asp-route-id="@role.Id" class="badge badge-subtle-primary me-1 my-1 fs-6">
                            @role.Name
                        </a>
                    }
                }
                else
                {
                    <div class="alert alert-secondary alert-outline mb-0" role="alert">
                        <div class="alert-icon">
                            <i data-lucide="info"></i>
                        </div>
                        <div class="alert-message">
                            @Localizer["This user has not been assigned any roles."]
                        </div>
                    </div>
                }
            </div>
        </div>
        <div class="card flex-fill mb-4">
            <div class="card-header">
                <h5 class="card-title mb-0"><i class="align-middle me-2" data-lucide="shield-check"></i> @Localizer["Effective Permissions"]</h5>
            </div>
            @if (Model.Permissions.Any())
            {
                <div class="list-group list-group-flush">
                    @foreach (var permission in Model.Permissions)
                    {
                        <div class="list-group-item">
                            <strong>@PermissionLocalizer[permission.Name]</strong>
                            <p class="text-muted mb-0">@PermissionLocalizer[permission.Description]</p>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="card-body">
                    <div class="alert alert-primary alert-outline mb-0" role="alert">
                        <div class="alert-icon">
                            <i data-lucide="info"></i>
                        </div>
                        <div class="alert-message">
                            @Localizer["This user has no effective permissions."]
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="card flex-fill mb-4">
            <div class="card-header">
                <h5 class="card-title mb-0"><i class="align-middle me-2" data-lucide="thumbs-up"></i> @Localizer["Like History"]</h5>
            </div>
            @if (Model.Likes.Any())
            {
                <div class="list-group list-group-flush">
                    @foreach (var like in Model.Likes)
                    {
                        <div class="list-group-item">
                            <div class="d-flex justify-content-between align-items-center">
                                <a href="/@(like.Document.FilePath[..^3].Replace('\\', '/')).html" class="text-decoration-none">@like.Document.Title</a>
                                <label data-utc-time="@like.CreatedAt.ToHtmlDateTime()" class="text-muted text-monospace small mb-0"></label>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="card-body">
                    <div class="alert alert-secondary alert-outline mb-0" role="alert">
                        <div class="alert-icon">
                            <i data-lucide="info"></i>
                        </div>
                        <div class="alert-message">
                            @Localizer["This user has no likes."]
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="card flex-fill mb-4">
            <div class="card-header">
                <h5 class="card-title mb-0"><i class="align-middle me-2" data-lucide="message-square"></i> @Localizer["Comment History"]</h5>
            </div>
            @if (Model.Comments.Any())
            {
                <div class="list-group list-group-flush">
                    @foreach (var comment in Model.Comments)
                    {
                        <div class="list-group-item">
                            <div class="d-flex justify-content-between align-items-start">
                                <div class="flex-grow-1 me-3">
                                    <div class="mb-1">
                                        <a href="/@(comment.Document.FilePath[..^3].Replace('\\', '/')).html" class="text-decoration-none fw-semibold">@comment.Document.Title</a>
                                    </div>
                                    <p class="mb-1">@comment.Content</p>
                                    <label data-utc-time="@comment.CreatedAt.ToHtmlDateTime()" class="text-muted text-monospace small mb-0"></label>
                                </div>
                                @if ((await AuthorizationService.AuthorizeAsync(User, AppPermissionNames.CanEditUsers)).Succeeded)
                                {
                                    <form asp-action="DeleteComment" method="post" class="ms-2" onsubmit="return confirm('@Localizer["Are you sure you want to delete this comment?"]')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="commentId" value="@comment.CommentId" />
                                        <input type="hidden" name="userId" value="@Model.User.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i data-lucide="trash-2" class="me-1" style="width:16px;height:16px;"></i> @Localizer["Delete"]
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="card-body">
                    <div class="alert alert-secondary alert-outline mb-0" role="alert">
                        <div class="alert-icon">
                            <i data-lucide="info"></i>
                        </div>
                        <div class="alert-message">
                            @Localizer["This user has no comments."]
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="card flex-fill mb-4">
            <div class="card-header">
                <h5 class="card-title mb-0"><i class="align-middle me-2" data-lucide="heart"></i> @Localizer["Favorite History"]</h5>
            </div>
            @if (Model.Favorites.Any())
            {
                <div class="list-group list-group-flush">
                    @foreach (var fav in Model.Favorites)
                    {
                        <div class="list-group-item">
                            <div class="d-flex justify-content-between align-items-center">
                                <a href="/@(fav.Document.FilePath[..^3].Replace('\\', '/')).html" class="text-decoration-none">@fav.Document.Title</a>
                                <label data-utc-time="@fav.CreatedAt.ToHtmlDateTime()" class="text-muted text-monospace small mb-0"></label>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="card-body">
                    <div class="alert alert-secondary alert-outline mb-0" role="alert">
                        <div class="alert-icon">
                            <i data-lucide="info"></i>
                        </div>
                        <div class="alert-message">
                            @Localizer["This user has no favorites."]
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
