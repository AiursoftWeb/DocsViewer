@using Aiursoft.WebTools
@model Aiursoft.DocsViewer.Models.DocumentsViewModels.DetailViewModel
@inject Aiursoft.DocsViewer.Services.FileStorage.StorageService Storage
@{
    <link rel="stylesheet" href="~/styles/markdown-reader.css" asp-append-version="true" />
}

<div class="container-fluid mt-3">
    <div class="row">
        <!-- Sidebar Tree Column -->
        
        
        <!-- Main Content Column -->
        <div class="col-md-12">
            <!-- Document Header -->
            <div class="d-flex justify-content-between align-items-center mb-3 pb-3 border-bottom">
                <div class="d-flex align-items-center">
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb mb-0">
                            <li class="breadcrumb-item"><a href="/"><i class="lucide lucide-home" style="width:14px;height:14px;"></i> @Localizer["Home"]</a></li>
                            <li class="breadcrumb-item"><a href="/Documents/Index?category=@Uri.EscapeDataString(Model.Document.Category)">@Model.CategoryDisplayName</a></li>
                            <li class="breadcrumb-item active" aria-current="page">@Model.PageTitle</li>
                        </ol>
                    </nav>
                    @if (Model.Document.SourceCulture != null)
                    {
                        <span class="badge bg-secondary ms-3" title="@Localizer["Original language of this document"]">@Model.Document.SourceCulture</span>
                    }
                </div>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="d-flex gap-2 align-items-center flex-wrap">
                        @if (Model.GitHubEditUrl != null)
                        {
                            <a href="@Model.GitHubEditUrl" target="_blank" class="btn btn-outline-secondary">
                                <i data-lucide="edit-3" class="align-middle me-1"></i> @Localizer["Edit on GitHub"]
                            </a>
                        }
                        @if (Model.ShowSimilarDocumentsButton)
                        {
                            <a href="/Documents/Similar/@Model.Document.Id" class="btn btn-outline-primary">
                                <i data-lucide="git-commit" class="align-middle me-1"></i> @Localizer["Similar"]
                            </a>
                        }
                        <form asp-controller="Likes" asp-action="Toggle" method="post" class="m-0">
                            <input type="hidden" name="documentId" value="@Model.Document.Id" />
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn @(Model.IsLiked ? "btn-warning" : "btn-outline-warning")">
                                <i data-lucide="thumbs-up" class="align-middle me-1"></i>
                                @(Model.IsLiked ? Localizer["Liked"] : Localizer["Like"])
                                <span class="badge @(Model.IsLiked ? "bg-white text-dark" : "bg-warning text-dark") ms-1">@Model.LikeCount</span>
                            </button>
                        </form>
                        <form asp-controller="Favorites" asp-action="Toggle" method="post" class="m-0">
                            <input type="hidden" name="documentId" value="@Model.Document.Id" />
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn @(Model.IsFavorited ? "btn-danger" : "btn-outline-danger")">
                                <i data-lucide="heart" class="align-middle me-1"></i>
                                @(Model.IsFavorited ? Localizer["Favorited"] : Localizer["Favorite"])
                            </button>
                        </form>
                    </div>
                }
                else
                {
                    <div class="d-flex gap-2 align-items-center flex-wrap">
                        @if (Model.GitHubEditUrl != null)
                        {
                            <a href="@Model.GitHubEditUrl" target="_blank" class="btn btn-outline-secondary">
                                <i data-lucide="edit-3" class="align-middle me-1"></i> @Localizer["Edit on GitHub"]
                            </a>
                        }
                        @if (Model.ShowSimilarDocumentsButton)
                        {
                            <a href="/Documents/Similar/@Model.Document.Id" class="btn btn-outline-primary">
                                <i data-lucide="git-commit" class="align-middle me-1"></i> @Localizer["Similar"]
                            </a>
                        }
                        <a href="/Account/Login?returnUrl=@Uri.EscapeDataString(Context.Request.Path + Context.Request.QueryString)" class="btn btn-outline-warning">
                            <i data-lucide="thumbs-up" class="align-middle me-1"></i>
                            @Localizer["Like"]
                            @if (Model.LikeCount > 0)
                            {
                                <span class="badge bg-warning text-dark ms-1">@Model.LikeCount</span>
                            }
                        </a>
                    </div>
                }
            </div>

            @if (Model.ShowTranslationNotice)
            {
                <div class="alert alert-warning alert-outline alert-dismissible" role="alert">
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    <div class="alert-icon">
                        <i class="lucide lucide-alert-triangle"></i>
                    </div>
                    <div class="alert-message">
                        <strong>@Localizer["AI Translation Notice"]</strong> — @Localizer["This document was originally written in"] <strong>@Model.SourceLanguageName</strong>.
                        @Localizer["You are reading an AI-generated machine translation, which may contain inaccuracies."]
                    </div>
                </div>
            }

            <!-- Document Content -->
            <div class="card shadow-sm mb-4">
                <div class="card-body markdown-content p-4">
                    @Html.Raw(Model.RenderedMarkdown)
                </div>
                
                <div class="card-footer bg-light p-3 border-top-0 d-flex justify-content-between align-items-center">
                    <div class="text-muted small">
                        <i class="lucide lucide-clock"></i> @Localizer["Last updated:"] <label class="d-inline text-muted" data-utc-time="@Model.Document.FileLastModified.ToHtmlDateTime()"></label>
                        @if (Model.ShowTranslationNotice && Model.LocalizedDocument != null)
                        {
                            <span class="ms-3"><i class="lucide lucide-languages"></i> @Localizer["Last translated:"] <label class="d-inline text-muted" data-utc-time="@Model.LocalizedDocument.LastLocalizedAt.ToHtmlDateTime()"></label></span>
                        }
                    </div>
                        <!-- Bottom buttons removed to match HowToCookViewer cleanly -->
                </div>
            </div>

            <!-- Contributors Section -->
            @if (Model.Contributors.Count > 0)
            {
                <div class="mt-4">
                    <h5 class="mb-3 d-flex align-items-center">
                        <div>
                            <i data-lucide="users" class="align-middle me-1"></i>
                            @Localizer["Contributors"]
                        </div>
                        @if (Model.GitHubHistoryUrl != null)
                        {
                            <a href="@Model.GitHubHistoryUrl" target="_blank" rel="noopener noreferrer"
                               class="btn btn-sm btn-outline-secondary ms-3">
                                <i data-lucide="history" class="align-middle me-1"></i>
                                @Localizer["Change History"]
                            </a>
                        }
                    </h5>
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var contributor in Model.Contributors)
                        {
                            <a href="@contributor.GitHubProfileUrl" target="_blank" rel="noopener noreferrer"
                               title="@contributor.Name (@contributor.CommitCount @Localizer["commits"])"
                               class="d-inline-block">
                                <img src="@contributor.AvatarUrl" alt="@contributor.Name"
                                     class="rounded-circle border shadow-sm" width="40" height="40"
                                     style="object-fit: cover;" />
                            </a>
                        }
                    </div>
                </div>
            }

            <!-- Comments Section -->
            <div id="comments" class="mt-4">
                <h5 class="mb-3">
                    <i data-lucide="message-circle" class="align-middle me-1"></i>
                    @Localizer["Comments"] (@Model.Comments.Count)
                </h5>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="card mb-4">
                        <div class="card-body">
                            <form asp-controller="Comments" asp-action="Post" method="post">
                                <input type="hidden" name="documentId" value="@Model.Document.Id" />
                                @Html.AntiForgeryToken()
                                <div class="mb-2">
                                    <textarea name="content" class="form-control" rows="3"
                                              placeholder="@Localizer["Write your comment…"]" maxlength="1000" required></textarea>
                                </div>
                                <button type="submit" class="btn btn-primary btn-sm">@Localizer["Post Comment"]</button>
                            </form>
                        </div>
                    </div>
                }

                @foreach (var comment in Model.Comments)
                {
                    <div class="card mb-3" id="comment-@comment.Id">
                        <div class="card-body">
                            <div class="d-flex gap-3">
                                <img src="@Storage.RelativePathToInternetUrl(comment.User.AvatarRelativePath)?w=72&square=true"
                                     alt="@(comment.User.DisplayName)"
                                     class="rounded-circle flex-shrink-0"
                                     width="40" height="40" />
                                <div class="flex-grow-1">
                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                        <div>
                                            <strong class="me-2">@(comment.User.DisplayName)</strong>
                                            <small class="text-muted"><label data-utc-time="@comment.CreatedAt.ToHtmlDateTime()"></label></small>
                                        </div>
                                        @if (User.Identity?.Name == comment.User.UserName)
                                        {
                                            <form asp-controller="Comments" asp-action="Delete" method="post" class="d-inline">
                                                <input type="hidden" name="commentId" value="@comment.Id" />
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-link btn-sm text-danger p-0"
                                                        onclick="return confirm('@Localizer["Are you sure you want to delete this comment and all its replies?"]')">@Localizer["Delete"]</button>
                                            </form>
                                        }
                                    </div>
                                    <p class="mb-2">@comment.Content</p>

                                    <!-- Replies -->
                                    @if (comment.Replies.Count > 0)
                                    {
                                        <div class="border-start ps-3 mt-2">
                                            @foreach (var reply in comment.Replies.OrderBy(r => r.CreatedAt))
                                            {
                                                <div class="d-flex gap-2 mb-2 pt-2" id="comment-@reply.Id">
                                                    <img src="@(Storage.RelativePathToInternetUrl(reply.User.AvatarRelativePath))?w=48&square=true"
                                                         alt="@(reply.User.DisplayName)"
                                                         class="rounded-circle flex-shrink-0"
                                                         width="32" height="32" />
                                                    <div class="flex-grow-1">
                                                        <div class="d-flex justify-content-between align-items-center mb-1">
                                                            <div>
                                                                <strong class="me-2">@(reply.User.DisplayName)</strong>
                                                                <small class="text-muted"><label data-utc-time="@reply.CreatedAt.ToHtmlDateTime()"></label></small>
                                                            </div>
                                                            @if (User.Identity?.Name == reply.User.UserName)
                                                            {
                                                                <form asp-controller="Comments" asp-action="Delete" method="post" class="d-inline">
                                                                    <input type="hidden" name="commentId" value="@reply.Id" />
                                                                    @Html.AntiForgeryToken()
                                                                    <button type="submit" class="btn btn-link btn-sm text-danger p-0"
                                                                            onclick="return confirm('@Localizer["Are you sure you want to delete this reply?"]')">@Localizer["Delete"]</button>
                                                                </form>
                                                            }
                                                        </div>
                                                        <p class="mb-0">@reply.Content</p>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    }

                                    <!-- Reply Form -->
                                    @if (User.Identity?.IsAuthenticated == true)
                                    {
                                        <div class="mt-2">
                                            <a class="btn btn-link btn-sm p-0 text-secondary toggle-reply"
                                               data-target="reply-form-@comment.Id">@Localizer["Reply"]</a>
                                            <div id="reply-form-@comment.Id" class="d-none mt-2">
                                                <form asp-controller="Comments" asp-action="Post" method="post">
                                                    <input type="hidden" name="documentId" value="@Model.Document.Id" />
                                                    <input type="hidden" name="parentCommentId" value="@comment.Id" />
                                                    @Html.AntiForgeryToken()
                                                    <div class="mb-1">
                                                        <textarea name="content" class="form-control form-control-sm" rows="2"
                                                                  placeholder="@string.Format(Localizer["Reply to {0}..."].Value, comment.User.DisplayName)"
                                                                  maxlength="1000" required></textarea>
                                                    </div>
                                                    <button type="submit" class="btn btn-secondary btn-sm">@Localizer["Send Reply"]</button>
                                                </form>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }

                @if (Model.Comments.Count == 0)
                {
                    <p class="text-muted text-center py-3">@Localizer["No comments yet. Be the first to leave one!"]</p>
                }

                @if (User.Identity?.IsAuthenticated != true)
                {
                    <div class="text-center py-3">
                        <a href="/Account/Login?returnUrl=@Uri.EscapeDataString(Context.Request.Path + Context.Request.QueryString)"
                           class="btn btn-outline-primary">
                            <i data-lucide="log-in" class="align-middle me-1"></i>
                            @Localizer["Login to comment"]
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('.toggle-reply').forEach(btn => {
            btn.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.getElementById(this.dataset.target);
                if (target) {
                    target.classList.toggle('d-none');
                    if (!target.classList.contains('d-none')) {
                        target.querySelector('textarea').focus();
                    }
                }
            });
        });
    });
</script>
    <partial name="_CodeAssets" />
