@using Aiursoft.WebTools
@model Aiursoft.DocsViewer.Models.DocumentsViewModels.DetailViewModel
@inject Aiursoft.DocsViewer.Services.FileStorage.StorageService Storage
@{
    <link rel="stylesheet" href="~/styles/markdown-reader.css" asp-append-version="true" />
}

<div class="container-fluid mt-3">
    <div class="row">
        <!-- Sidebar Tree Column -->
        
        
        <!-- Main Content Column -->
        <div class="col-md-12">
            <!-- Document Header -->
            <div class="d-flex justify-content-between align-items-center mb-3 pb-3 border-bottom">
                <div class="d-flex align-items-center">
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb mb-0">
                            <li class="breadcrumb-item"><a href="/"><i class="lucide lucide-home" style="width:14px;height:14px;"></i> Home</a></li>
                            <li class="breadcrumb-item"><a href="/Documents/Index?category=@Uri.EscapeDataString(Model.Document.Category)">@Model.CategoryDisplayName</a></li>
                            <li class="breadcrumb-item active" aria-current="page">@Model.PageTitle</li>
                        </ol>
                    </nav>
                    @if (Model.Document.SourceCulture != null)
                    {
                        <span class="badge bg-secondary ms-3" title="Original language of this document">@Model.Document.SourceCulture</span>
                    }
                </div>
                <div>
                    @if (Model.GitHubEditUrl != null)
                    {
                        <a href="@Model.GitHubEditUrl" target="_blank" class="btn btn-sm btn-outline-secondary me-2">
                            <i class="lucide lucide-edit-3"></i> Edit on GitHub
                        </a>
                    }
                    @if (Model.GitHubHistoryUrl != null)
                    {
                        <a href="@Model.GitHubHistoryUrl" target="_blank" class="btn btn-sm btn-outline-secondary">
                            <i class="lucide lucide-history"></i> History
                        </a>
                    }
                </div>
            </div>

            @if (Model.ShowTranslationNotice)
            {
                <div class="alert alert-warning alert-outline alert-dismissible" role="alert">
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    <div class="alert-icon">
                        <i class="lucide lucide-alert-triangle"></i>
                    </div>
                    <div class="alert-message">
                        <strong>AI Translation Notice</strong> — This document was originally written in <strong>@Model.SourceLanguageName</strong>.
                        You are reading an AI-generated machine translation, which may contain inaccuracies.
                    </div>
                </div>
            }

            <!-- Document Content -->
            <div class="card shadow-sm mb-4">
                <div class="card-body markdown-content p-4">
                    @Html.Raw(Model.RenderedMarkdown)
                </div>
                
                <div class="card-footer bg-light p-3 border-top-0 d-flex justify-content-between align-items-center">
                    <div class="text-muted small">
                        <i class="lucide lucide-clock"></i> Last updated: <label class="d-inline text-muted" data-utc-time="@Model.Document.FileLastModified.ToHtmlDateTime()"></label>
                    </div>
                    <div>
                        <!-- Actions: Like, Favorite, Similar -->
                        <div class="btn-group btn-group-sm shadow-sm" role="group">
                            <form asp-controller="Likes" asp-action="Toggle" method="post" class="d-inline">
                                <input type="hidden" name="documentId" value="@Model.Document.Id" />
                                <button type="submit" class="btn @(Model.IsLiked ? "btn-danger" : "btn-outline-danger")">
                                    <i class="lucide lucide-heart @(Model.IsLiked ? "fill-white" : "")"></i> Like (@Model.LikeCount)
                                </button>
                            </form>
                            <form asp-controller="Favorites" asp-action="Toggle" method="post" class="d-inline">
                                <input type="hidden" name="documentId" value="@Model.Document.Id" />
                                <button type="submit" class="btn @(Model.IsFavorited ? "btn-warning text-dark" : "btn-outline-warning text-dark")">
                                    <i class="lucide lucide-star @(Model.IsFavorited ? "fill-dark" : "")"></i> Favorite
                                </button>
                            </form>
                            @if (Model.ShowSimilarDocumentsButton)
                            {
                                <a href="/Documents/Similar/@Model.Document.Id" class="btn btn-outline-primary">
                                    <i class="lucide lucide-git-commit"></i> Similar
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Comments Section -->
            <div class="card border-0" id="comments">
                <div class="card-header bg-white">
                    <h5 class="mb-0"><i class="lucide lucide-message-square me-2"></i> Comments (@Model.Comments.Count)</h5>
                </div>
                <div class="card-body p-4">
                    @if (Model.Comments.Count == 0)
                    {
                        <p class="text-muted text-center my-4">No comments yet. Be the first to share your thoughts!</p>
                    }
                    else
                    {
                        <div class="comments-list">
                            @foreach (var comment in Model.Comments)
                            {
                                <div class="d-flex mb-4">
                                    <img src="@(Storage.RelativePathToInternetUrl(comment.User.AvatarRelativePath))?w=40&square=true" alt="Avatar" class="rounded-circle me-3" style="width: 40px; height: 40px; object-fit: cover;">
                                    <div class="flex-grow-1">
                                        <div class="bg-light p-3 rounded position-relative">
                                            <h6 class="mb-1 text-primary">@comment.User.DisplayName</h6>
                                            <p class="mb-0">@comment.Content</p>
                                            
                                            @if (User.Identity?.Name == comment.User.UserName)
                                            {
                                                <form asp-controller="Comments" asp-action="Delete" method="post" class="position-absolute top-0 end-0 m-2">
                                                    <input type="hidden" name="commentId" value="@comment.Id" />
                                                    <button type="submit" class="btn btn-sm btn-link text-danger p-0" title="Delete comment"><i class="lucide lucide-trash-2" style="width:16px;"></i></button>
                                                </form>
                                            }
                                        </div>
                                        <div class="mt-1 ms-2 small">
                                            <label class="text-muted" data-utc-time="@comment.CreatedAt.ToHtmlDateTime()"></label>
                                            <a href="javascript:void(0);" class="text-decoration-none ms-3 text-secondary reply-btn" data-comment-id="@comment.Id">Reply</a>
                                        </div>
                                        
                                        <!-- Replies -->
                                        @if (comment.Replies.Any())
                                        {
                                            <div class="mt-3">
                                                @foreach (var reply in comment.Replies.OrderBy(r => r.CreatedAt))
                                                {
                                                    <div class="d-flex mb-3">
                                                        <img src="@(Storage.RelativePathToInternetUrl(reply.User.AvatarRelativePath))?w=32&square=true" alt="Avatar" class="rounded-circle me-3" style="width: 32px; height: 32px; object-fit: cover;">
                                                        <div class="flex-grow-1">
                                                            <div class="bg-light p-2 rounded position-relative">
                                                                <h6 class="mb-1 text-primary small">@reply.User.DisplayName</h6>
                                                                <p class="mb-0 small">@reply.Content</p>
                                                                
                                                                @if (User.Identity?.Name == reply.User.UserName)
                                                                {
                                                                    <form asp-controller="Comments" asp-action="Delete" method="post" class="position-absolute top-0 end-0 m-1">
                                                                        <input type="hidden" name="commentId" value="@reply.Id" />
                                                                        <button type="submit" class="btn btn-sm btn-link text-danger p-0" title="Delete reply"><i class="lucide lucide-trash-2" style="width:14px;"></i></button>
                                                                    </form>
                                                                }
                                                            </div>
                                                            <div class="mt-1 ms-2 small text-muted">
                                                                <label class="text-muted" data-utc-time="@reply.CreatedAt.ToHtmlDateTime()"></label>
                                                            </div>
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        }

                                        <!-- Reply Form -->
                                        <div class="reply-form mt-2 d-none" id="reply-form-@comment.Id">
                                            <form asp-controller="Comments" asp-action="Post" method="post">
                                                <input type="hidden" name="documentId" value="@Model.Document.Id" />
                                                <input type="hidden" name="parentCommentId" value="@comment.Id" />
                                                <div class="input-group input-group-sm">
                                                    <input type="text" name="content" class="form-control" placeholder="Write a reply..." required maxlength="1000">
                                                    <button type="submit" class="btn btn-primary">Reply</button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }

                    <hr class="my-4" />

                    <!-- Main Comment Form -->
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <form asp-controller="Comments" asp-action="Post" method="post">
                            <input type="hidden" name="documentId" value="@Model.Document.Id" />
                            <div class="mb-3">
                                <label for="content" class="form-label">Leave a comment</label>
                                <textarea name="content" id="content" class="form-control" rows="3" required maxlength="1000" placeholder="What are your thoughts?"></textarea>
                            </div>
                            <div class="text-end">
                                <button type="submit" class="btn btn-primary px-4">Post Comment</button>
                            </div>
                        </form>
                    }
                    else
                    {
                        <div class="alert alert-secondary text-center">
                            Please <a href="/Account/Login?returnUrl=@Uri.EscapeDataString(Context.Request.Path)">log in</a> to leave a comment.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('.reply-btn').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var id = this.getAttribute('data-comment-id');
                var form = document.getElementById('reply-form-' + id);
                if (form.classList.contains('d-none')) {
                    form.classList.remove('d-none');
                    form.querySelector('input[name="content"]').focus();
                } else {
                    form.classList.add('d-none');
                }
            });
        });
    });
</script>
    <partial name="_CodeAssets" />
