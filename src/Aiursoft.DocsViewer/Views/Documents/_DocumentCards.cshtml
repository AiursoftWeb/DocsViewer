@using Aiursoft.WebTools
@model Aiursoft.DocsViewer.Models.DocumentsViewModels.DocumentCardsViewModel

@foreach (var doc in Model.Documents)
{
    var title = Model.LocalizedTitles.GetValueOrDefault(doc.Id, doc.Title);
    var contentPreview = Model.LocalizedContents.GetValueOrDefault(doc.Id, doc.Content);
    // Strip markdown roughly for preview
    contentPreview = System.Text.RegularExpressions.Regex.Replace(contentPreview, @"[#*`>]", "").Trim();
    if (contentPreview.Length > 150)
    {
        contentPreview = contentPreview.Substring(0, 150) + "...";
    }

    <div class="col-md-6 col-lg-4 mb-4">
        <div class="card h-100 shadow-sm recipe-card transition-hover">
            <div class="card-body">
                <h5 class="card-title text-primary text-truncate" title="@title">@title</h5>
                <h6 class="card-subtitle mb-2 text-muted small">
                    <i class="lucide lucide-folder"></i> @(string.IsNullOrEmpty(doc.Category) ? "Uncategorized" : doc.Category)
                    @if (doc.SourceCulture != null)
                    {
                        <span class="badge bg-secondary ms-1">@doc.SourceCulture</span>
                    }
                </h6>
                <p class="card-text text-muted small" style="height: 60px; overflow: hidden;">
                    @contentPreview
                </p>
            </div>
            <div class="card-footer bg-transparent border-top-0">
                <div class="d-flex justify-content-between align-items-center">
                    <div class="text-muted small">
                        <i class="lucide lucide-heart text-danger"></i> @Model.LikeCounts.GetValueOrDefault(doc.Id, 0)
                        <span class="mx-1">&bull;</span>
                        <i class="lucide lucide-clock"></i> <label class="d-inline" data-utc-time="@doc.FileLastModified.ToHtmlDateTime()"></label>
                    </div>
                    <a href="/@(doc.FilePath[..^3].Replace('\\', '/')).html" class="btn btn-sm btn-outline-primary stretched-link">Read</a>
                </div>
            </div>
        </div>
    </div>
}
